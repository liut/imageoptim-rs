# Build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo
# (binary project: keep Cargo.lock for reproducible builds)
# Un-ignore Cargo.lock specifically; the global gitignore's `*.lock`
# rule (from ~/.gitignore_global) would otherwise drop it.
!Cargo.lock

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local overrides
*.local.*

# Local-only test fixtures (not part of the regression suite — generated
# on demand for ad-hoc visual comparison)
tests/fixtures/

# The single binary fixture the test suite reads. Generated by
# `cargo run --example gen-fixtures`. Not committed to keep the repo
# lean; the regression suite skips cleanly if the file is missing.
tests/example*.png
*.bak


# Added by cargo

/target
